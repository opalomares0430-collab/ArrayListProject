package module6;

public class Student {
    int rollno;
    String name;
    String address;

    // Constructor
    public Student(int rollno, String name, String address) {
        this.rollno = rollno;
        this.name = name;
        this.address = address;
    }

    // Display method
    public void display() {
        System.out.println("Roll No: " + rollno + 
                           ", Name: " + name + 
                           ", Address: " + address);
    }
}
